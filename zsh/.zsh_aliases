alias "cd.."="cd .."
alias c="clear"
alias cz="cd ~/zeehawk"
alias b="bat"
alias h="history -E"

#ohmyzsh aliases
alias szshrc="source ~/.zshrc"

#git aliases
alias gs="git status"
alias gc="git checkout"
alias gcb="git checkout -b"
alias gb="git branch"
alias ga='git add'
alias gA='git add -A'
alias gcf='gc $(gb | fzf)'
alias gcf='gc $(git branch --sort=-committerdate | tr -d " *" | fzf --preview="git log {} | bat --color=always --style=numbers --line-range=:500")'
alias gp='git pull'
#git log options
alias hlog='git log --all --graph --format="%C(yellow)%h %C(reset)%an %C(blue)%ar %C(red)%d %C(reset)%s"'
alias xlog='git log --graph --format="%C(yellow)%h %C(reset)%an %C(blue)%ar %C(red)%d %C(reset)%s"'
alias slog='git log --stat --all --graph --format="%C(yellow)%h %C(reset)%an %C(blue)%ar %C(red)%d %C(reset)%s"'
alias mlog='git log --all --graph --format="%C(yellow)%h %C(red)%d %C(reset)%s"'
#vim aliases
alias v='nvim'
alias v.='nvim .'
alias nvc='v ~/.dotfiles/nvim/.config/nvim/'
alias dfp='(cd ~/.dotfiles; git add .; git commit -m "update dotfiles"; echo "NICE")'

alias f="fzf --multi --preview 'bat --style=numbers --color=always {} | head -400'"

vf() {
  # We use ${(f)...} to split the output of 'f' by newlines
  local files=(${(f)"$(f)"})
  
  # Check if the array is NOT empty
  if [[ -n "$files" ]]; then
    nvim "${files[@]}"
  fi
}

vfd() {
  local dir=$(find . -type d -print | fzf --preview "tree -a -C -L 1 {}")
  if [[ -n "$dir" ]]; then
    nvim "$dir"
  fi
}

#fzf aliases 
#tmux aliases
alias t='tmux'
alias tn='tmux new -s'
alias ta='tmux attach -t'
alias tl='tmux ls'
